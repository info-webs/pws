# WordPress source
WP_BASE_URL=https://www.posicionamiento-web-salamanca.com
WP_USER=jesus
# Application password from WordPress → Users → Profile → Application Passwords.
# Spaces are fine — the script strips them before Basic-auth encoding.
WP_APP_PASSWORD=MjCP M610 gNXr 04Lb S0fH OeAi

# Notion destination
# Create an internal integration at https://www.notion.so/my-integrations,
# share the target database with it, paste the integration secret here.
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion DB ID / data source ID (32 hex chars, from the DB URL).
# scripts/import-wp-blog-to-notion.mjs uses NOTION_DS_ID.
# scripts/migrate-wp-to-notion.mjs (older) uses NOTION_BLOG_DB_ID.
NOTION_DS_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_BLOG_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional
# OFFSET=30          # skip the first N posts (already imported). Default 30.
# DRY_RUN=1          # list posts without creating anything (import-wp-blog only)
# VERBOSE=1          # print stack traces for errors
