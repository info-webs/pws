---
import type { GetStaticPaths } from "astro";
import ClaudeLayout from "@layouts/ClaudeLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import BlogHero from "@components/blog/BlogHero.astro";
import PostCard from "@components/blog/PostCard.astro";
import Pagination from "@components/blog/Pagination.astro";
import { getAllPosts, getCategories } from "../../lib/notion";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getAllPosts();
  return paginate(posts, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const categories = await getCategories();

const title =
  page.currentPage === 1
    ? "Blog — Posicionamiento Web Salamanca"
    : `Blog · página ${page.currentPage} — Posicionamiento Web Salamanca`;
const description =
  "Artículos prácticos de SEO, marketing digital y posicionamiento web por el equipo de posicionamiento-web-salamanca.com.";
const canonical =
  page.currentPage === 1
    ? "https://www.posicionamiento-web-salamanca.com/blog"
    : `https://www.posicionamiento-web-salamanca.com/blog/${page.currentPage}`;
---

<ClaudeLayout title={title} description={description} canonical={canonical} includeFaq={false}>
  <Header />
  <main>
    <BlogHero
      eyebrow="Blog"
      title="Aprende SEO de verdad, gratis."
      accent="SEO"
      lead="Artículos prácticos sobre posicionamiento web, marketing digital y todo lo que aplicamos a diario con nuestros clientes en Salamanca."
    />

    <section class="section section-tight">
      <div class="container">
        {categories.length > 0 && (
          <div class="cat-chips">
            <a class="chip is-active" href="/blog">Todos <span>{page.total}</span></a>
            {categories.map((c) => (
              <a class="chip" href={`/blog/categoria/${c.slug}`}>
                {c.name} <span>{c.count}</span>
              </a>
            ))}
          </div>
        )}

        <div class="blog-grid">
          {page.data.map((post, idx) => (
            <PostCard
              post={post}
              variant={idx === 0 && page.currentPage === 1 ? "featured" : "default"}
            />
          ))}
        </div>

        <Pagination
          prevUrl={page.url.prev}
          nextUrl={page.url.next}
          current={page.currentPage}
          total={page.lastPage}
        />
      </div>
    </section>
  </main>
  <Footer />
</ClaudeLayout>

<style>
  .cat-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 999px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    font-size: 13.5px;
    color: var(--text-2);
    transition: all 0.2s;
  }
  .chip span {
    font-family: var(--ff-mono);
    font-size: 11px;
    color: var(--text-3);
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip.is-active {
    background: var(--text);
    color: #F5F1E8;
    border-color: var(--text);
  }
  .chip.is-active span { color: rgba(245, 241, 232, 0.6); }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .blog-grid :global(.blog-card.featured) { grid-column: span 2; }
  @media (max-width: 880px) {
    .blog-grid { grid-template-columns: 1fr 1fr; }
    .blog-grid :global(.blog-card.featured) { grid-column: span 2; }
  }
  @media (max-width: 600px) {
    .blog-grid { grid-template-columns: 1fr; }
    .blog-grid :global(.blog-card.featured) { grid-column: span 1; }
  }
</style>
