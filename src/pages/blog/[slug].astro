---
import type { GetStaticPaths } from "astro";
import ClaudeLayout from "@layouts/ClaudeLayout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import PostCard from "@components/blog/PostCard.astro";
import Prose from "@components/blog/Prose.astro";
import { getAllPosts, getPostBySlug } from "../../lib/notion";

export const getStaticPaths = (async () => {
  const posts = await getAllPosts();
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { meta: p },
  }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);
if (!post) {
  return Astro.redirect("/404");
}

const all = await getAllPosts();
const idx = all.findIndex((p) => p.slug === post.slug);
const related = all
  .filter((p, i) => i !== idx && p.categorySlug === post.categorySlug)
  .slice(0, 3);

const SITE = "https://www.posicionamiento-web-salamanca.com";
const canonical = `${SITE}/blog/${post.slug}`;
const ogImage = post.coverUrl || `${SITE}/opengraph.jpg`;

const dateLabel = post.publishedDate
  ? new Date(post.publishedDate).toLocaleDateString("es-ES", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
const readMin = Math.max(3, Math.min(25, Math.ceil(post.html.length / 1400)));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": canonical + "#article",
  headline: post.title,
  description: post.seoDescription || post.excerpt,
  url: canonical,
  datePublished: post.publishedDate || undefined,
  dateModified: post.updatedDate || post.publishedDate || undefined,
  image: post.coverUrl || ogImage,
  articleSection: post.category,
  author: {
    "@type": "Person",
    name: "Jesús López",
    url: "https://www.linkedin.com/in/jesuslopezseo/",
  },
  publisher: {
    "@type": "Organization",
    name: "Posicionamiento Web Salamanca",
    logo: {
      "@type": "ImageObject",
      url: `${SITE}/favicon.svg`,
    },
  },
  mainEntityOfPage: canonical,
};
---

<ClaudeLayout
  title={`${post.seoTitle || post.title} — Posicionamiento Web Salamanca`}
  description={post.seoDescription || post.excerpt}
  canonical={canonical}
  ogImage={ogImage}
  includeFaq={false}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <Header />

  <main>
    <article class="post">
      <header class="post-head">
        <div class="container">
          <a class="back" href="/blog">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"></path></svg>
            Volver al blog
          </a>
          <div class="post-meta">
            <a class="post-cat" href={`/blog/categoria/${post.categorySlug}`}>{post.category}</a>
            <span class="dot">·</span>
            <time datetime={post.publishedDate}>{dateLabel}</time>
            <span class="dot">·</span>
            <span>{readMin} min lectura</span>
          </div>
          <h1>{post.title}</h1>
          {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
          {post.coverUrl && (
            <div class="post-cover">
              <img src={post.coverUrl} alt={post.title} loading="eager" />
            </div>
          )}
        </div>
      </header>

      <div class="container post-body">
        <Prose html={post.html} />
      </div>
    </article>

    {related.length > 0 && (
      <section class="section section-tight related">
        <div class="container">
          <div class="section-head" style="margin-bottom: 36px;">
            <span class="h-eyebrow">Relacionados</span>
            <h2>Más de <em>{post.category}</em></h2>
          </div>
          <div class="related-grid">
            {related.map((r) => <PostCard post={r} />)}
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</ClaudeLayout>

<style>
  .post-head {
    padding-top: 130px;
    padding-bottom: 40px;
    position: relative;
    background: linear-gradient(180deg, var(--surface-warm) 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--border);
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--ff-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-3);
    margin-bottom: 28px;
    transition: color 0.2s;
  }
  .back:hover { color: var(--accent); }
  .back svg { width: 12px; height: 12px; }
  .post-meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--ff-mono);
    font-size: 12px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .post-cat { color: var(--accent); }
  .post-meta .dot { opacity: 0.6; }
  .post-head h1 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(36px, 5.5vw, 64px);
    line-height: 1;
    letter-spacing: -0.025em;
    text-wrap: balance;
    max-width: 900px;
  }
  .post-excerpt {
    margin-top: 22px;
    color: var(--text-2);
    font-size: clamp(17px, 1.3vw, 21px);
    line-height: 1.5;
    max-width: 720px;
    text-wrap: pretty;
  }
  .post-cover {
    margin-top: 36px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 8;
    box-shadow: var(--shadow-lg);
  }
  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .post-body {
    padding-block: clamp(48px, 6vw, 96px);
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  @media (max-width: 900px) { .related-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .related-grid { grid-template-columns: 1fr; } }
  .related h2 em { color: var(--accent); font-style: italic; }
</style>
