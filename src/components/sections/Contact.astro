---
---

<section class="section" id="contacto" aria-labelledby="contact-title">
  <div class="container">
    <div class="contact">
      <div class="contact-bg" aria-hidden="true"></div>
      <div class="contact-grid">
        <div class="contact-left">
          <span class="h-eyebrow" style="color: rgba(245,241,232,0.5);">Hablemos</span>
          <h2 id="contact-title">
            Cuéntanos tu proyecto.<br />
            Te respondemos en <em>menos de 24h</em>.
          </h2>
          <p class="lead">
            Sin compromiso, sin venta agresiva. Una llamada de 30 minutos para entender
            si podemos ayudarte y, si no, derivarte a alguien que sí.
          </p>
          <div class="contact-info">
            <div class="contact-line">
              <div class="contact-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
              </div>
              <div>
                <div class="contact-line-lbl">Teléfono</div>
                <div class="contact-line-val"><a href="tel:+34618015995">+34 618 015 995</a></div>
              </div>
            </div>
            <div class="contact-line">
              <div class="contact-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </div>
              <div>
                <div class="contact-line-lbl">Email</div>
                <div class="contact-line-val"><a href="mailto:jesus@jesuslopezseo.com">jesus@jesuslopezseo.com</a></div>
              </div>
            </div>
            <div class="contact-line">
              <div class="contact-ic">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              </div>
              <div>
                <div class="contact-line-lbl">Dónde</div>
                <div class="contact-line-val">Salamanca, España</div>
              </div>
            </div>
          </div>
        </div>
        <form class="contact-right" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
          <input type="hidden" name="subject" value="Nueva propuesta desde posicionamiento-web-salamanca.com" />
          <div class="field-row">
            <div class="field">
              <label for="c-name">Nombre</label>
              <input id="c-name" name="name" type="text" required placeholder="Marta Castaño" />
            </div>
            <div class="field">
              <label for="c-phone">Teléfono</label>
              <input id="c-phone" name="phone" type="tel" required placeholder="+34 600 000 000" />
            </div>
          </div>
          <div class="field">
            <label for="c-email">Email</label>
            <input id="c-email" name="email" type="email" required placeholder="tu@email.com" />
          </div>
          <div class="field">
            <label for="c-sector">Sector</label>
            <select id="c-sector" name="sector" required>
              <option value="">Elige uno…</option>
              <option>Clínica dental</option>
              <option>Despacho de abogados</option>
              <option>Notaría</option>
              <option>Fisioterapia / salud</option>
              <option>Comercio local</option>
              <option>Otro</option>
            </select>
          </div>
          <div class="field">
            <label for="c-msg">Cuéntame tu proyecto</label>
            <textarea id="c-msg" name="message" rows="4" required placeholder="Web actual, objetivos, plazos…"></textarea>
          </div>
          <button type="submit" class="contact-submit">
            Enviar propuesta
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14M13 5l7 7-7 7"></path></svg>
          </button>
          <p class="contact-consent">
            Al enviar aceptas nuestra <a href="/privacidad">política de privacidad</a>.
            Solo usamos tus datos para responderte.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    background: var(--text);
    color: #F5F1E8;
    border-radius: var(--radius-xl);
    overflow: hidden;
    position: relative;
  }
  :global(:root[data-theme="dark"]) .contact { background: #0E0B08; }
  .contact-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 110% 0%, rgba(217, 119, 87, 0.35), transparent 60%),
      radial-gradient(ellipse 50% 40% at 0% 100%, rgba(244, 191, 166, 0.25), transparent 60%);
    pointer-events: none;
  }
  .contact-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }
  @media (max-width: 880px) { .contact-grid { grid-template-columns: 1fr; } }

  .contact-left {
    padding: clamp(36px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 32px;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  @media (max-width: 880px) {
    .contact-left { border-right: none; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
  }
  .contact-left h2 {
    font-family: var(--ff-display);
    font-weight: 400;
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.022em;
    margin-top: 14px;
    text-wrap: balance;
    color: #F5F1E8;
  }
  .contact-left h2 em { color: var(--accent-soft); font-style: italic; }
  .contact-left .lead {
    color: rgba(245, 241, 232, 0.7);
    font-size: 16px;
    line-height: 1.55;
    max-width: 420px;
    text-wrap: pretty;
  }
  .contact-info { display: flex; flex-direction: column; gap: 20px; margin-top: auto; }
  .contact-line { display: flex; align-items: center; gap: 14px; color: rgba(245, 241, 232, 0.85); }
  .contact-ic {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(217, 119, 87, 0.15);
    border: 1px solid rgba(217, 119, 87, 0.3);
    display: grid;
    place-items: center;
    color: var(--accent-soft);
    flex-shrink: 0;
  }
  .contact-ic :global(svg) { width: 18px; height: 18px; }
  .contact-line-lbl {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(245, 241, 232, 0.5);
    font-family: var(--ff-mono);
  }
  .contact-line-val { font-size: 15.5px; font-weight: 500; margin-top: 3px; }
  .contact-line-val a:hover { color: var(--accent-soft); }

  .contact-right {
    padding: clamp(36px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .field { display: flex; flex-direction: column; gap: 8px; }
  .field label {
    font-family: var(--ff-mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(245, 241, 232, 0.6);
  }
  .field input,
  .field select,
  .field textarea {
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    color: #F5F1E8;
    font-size: 15px;
    transition: all 0.25s;
    font-family: var(--ff-body);
  }
  .field textarea { resize: vertical; min-height: 90px; }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent-soft);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 0 4px rgba(217, 119, 87, 0.15);
  }
  .field input::placeholder,
  .field textarea::placeholder { color: rgba(245, 241, 232, 0.35); }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .contact-submit {
    background: var(--accent);
    color: #fff;
    padding: 16px;
    border-radius: 12px;
    font-weight: 500;
    font-size: 15px;
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.25s var(--ease);
  }
  .contact-submit:hover { background: var(--accent-hover); transform: translateY(-1px); }
  .contact-consent {
    font-size: 12px;
    color: rgba(245, 241, 232, 0.5);
    line-height: 1.5;
    margin-top: 6px;
  }
  .contact-consent a { text-decoration: underline; }
</style>
